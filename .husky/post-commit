#!/bin/sh

# Auto version bump: patch on every commit
# Use lock file to prevent re-entry from --amend
LOCK_FILE="/tmp/.husky-version-bump-lock"
if [ -f "$LOCK_FILE" ]; then
  exit 0
fi
touch "$LOCK_FILE"
trap 'rm -f "$LOCK_FILE"' EXIT

# Bump patch version
CURRENT_VERSION=$(node -p "require('./package.json').version")
IFS='.' read -r MAJOR MINOR PATCH <<EOF
$CURRENT_VERSION
EOF
NEW_PATCH=$((PATCH + 1))
NEW_VERSION="$MAJOR.$MINOR.$NEW_PATCH"

# Update package.json version in place
sed -i "s/\"version\": \"$CURRENT_VERSION\"/\"version\": \"$NEW_VERSION\"/" package.json

# Amend the current commit to include the version bump
git add package.json
git commit --amend --no-edit --no-verify
