{
  "name": "@pentoai/ml-ralph",
  "version": "0.4.5",
  "description": "Autonomous ML engineering agent with TUI",
  "module": "src/index.tsx",
  "type": "module",
  "bin": {
    "ml-ralph": "./src/index.tsx"
  },
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "dev": "bun run src/index.tsx",
    "typecheck": "bunx tsc --noEmit",
    "test": "bun test",
    "lint": "bunx @biomejs/biome check --write .",
    "lint:ci": "bunx @biomejs/biome check .",
    "check": "bun run lint:ci && bun run typecheck",
    "prepare": "husky"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/pentoai/ml-ralph.git"
  },
  "author": "Pento AI",
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/asciichart": "^1.5.8",
    "@types/bun": "^1.3.11",
    "@types/react": "^19.2.14",
    "husky": "^9.1.7",
    "react-devtools-core": "^7.0.1",
    "typescript": "^6.0.2"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@opentui/core": "^0.1.95",
    "@opentui/react": "^0.1.95",
    "asciichart": "^1.5.25",
    "node-pty": "^1.1.0",
    "react": "^19.2.4",
    "zustand": "^5.0.12"
  }
}
